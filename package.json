{
  "name": "modelforge-launcher",
  "version": "0.1.0",
  "description": "A lightweight desktop launcher for managing vanilla Minecraft installations.",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "check": "node scripts/check.js",
    "build": "electron-builder --mac tar.gz --publish never"
  },
  "keywords": [
    "electron",
    "minecraft",
    "launcher",
    "modelforge"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "dev.pxdns.modelforge",
    "productName": "ModelForge Launcher",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "renderer/**/*",
      "core/**/*",
      "instances/.gitkeep",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.games",
      "target": [
        "tar.gz"
      ]
    }
  }
}
